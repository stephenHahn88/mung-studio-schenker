# project
node_modules
.parcel-cache
dist
# build-output + ALL deploy-swap staging/backup copies (dist_new, dist_old, dist_old2,
# dist_edge, dist_collab, dist_fix, ...) — large, never commit
dist_*
dist.*
# pyodide package bundles are large build artifacts (never commit)
*.pyodide-packages
.mypy_cache
logs
__pycache__
simple-php-backend/__pycache__

# editors
.idea
# .vscode is not ignored - it has proper settings for tabsize

# operating system
.DS_Store

# dotenv
.env
.env.production

# local release data
models/**
!models/
!models/README.md
documents/*
!documents/.gitkeep
!documents/README.md
# one-off local data backups (kept on disk, never committed)
documents_backup_*

# secrets (real per-annotator tokens — never commit; use users.example.json as template)
simple-php-backend/users.json
